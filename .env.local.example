# ─────────────────────────────────────────────────────────────────────────
# FRONTEND ENVIRONMENT VARIABLES
#
# This file is a TEMPLATE committed to git.
# Local dev: copy to .env.local (which is gitignored).
# Production: set the values in Vercel dashboard
#             → Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────────────────

# Backend API URL.
#   Local dev:  http://localhost:3001
#   Production: https://api.perfectmarktutorschoolproject.com
NEXT_PUBLIC_API_URL=http://localhost:3001

# Frontend's own URL (used for absolute-URL generation in some places).
#   Local dev:  http://localhost:3000
#   Production: https://perfectmarktutorschoolproject.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Paystack public key — safe to expose; used by the Paystack JS SDK on the
# checkout side. Get from Paystack dashboard → Settings → API Keys.
#   Test mode: pk_test_...
#   Live mode: pk_live_...
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxx

# Optional sample HLS URL for the watch page when no real backend is wired.
# Leave empty in production.
NEXT_PUBLIC_SAMPLE_HLS_URL=
